{
  "name": "actions",
  "version": "1.0.0",
  "private": true,
  "description": "Custom actions for BookkeepersMC's repositories.",
  "main": "lib/index.js",
  "scripts": {
    "build": "ncc build src/main.ts --minify --out lib",
