    "string-argv": "^0.3.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "ts-jest": "^29.1.1",
    "@types/node": "20.8.2",
    "@vercel/ncc": "^0.38.1",
    "ts-jest": "^29.1.1",
    "all-contributors-cli": "^6.26.1",
    "eslint-config-prettier": "^9.1.0",
    "gts": "^5.3.0",
    "ts-jest": "^29.1.1",
    "typescript": "~5.4.5"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BookkeepersMC/actions.git"
