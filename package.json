{
  "name": "actions",
  "version": "1.0.0",
  "private": true,
  "description": "Custom Github action scripts for BookkeepersMC",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "prettier --write ./src",
    "check": "prettier --check ./src",
    "package": "ncc build --source-map --license licenses.txt",
    "all": "npm run check && npm run build && npm run package"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@octokit/core": "^6.1.2",
    "actions-toolkit": "^6.0.1",
    "js-yaml": "^4.1.0",
    "simple-git": "^3.18.0",
    "string-argv": "^0.3.2"
  },
  "devDependencies": {
    "@octokit/types": "^13.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "20.8.2",
    "@vercel/ncc": "^0.38.1",
    "all-contributors-cli": "^6.26.1",
    "eslint-config-prettier": "^9.1.0",
    "gts": "^5.3.0",
    "husky": "^9.0.11",
    "prettier": "3.0.3",
    "nock": "^13.3.3",
    "typescript": "~5.4.5"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BookkeepersMC/actions.git"
  },
  "keywords": [
    "github",
    "action",
    "version",
    "npm",
    "node"
  ],
  "author": "Cryptic",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/BookkeepersMC/actions/issues"
  },
  "homepage": "https://github.com/BookkeepersMC/actions#readme"
}
